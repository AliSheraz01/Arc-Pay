// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  address   String   @unique
  username  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id                String   @id @default(uuid())
  txHash            String
  fromAddress       String
  toAddress         String
  amount            String
  memo              String?
  status            String   @default("COMPLETED") // PENDING, COMPLETED, FAILED, RECOVERED
  blockNumber       Int
  sourceChain       Int?     // chainId
  destinationChain  Int?     // chainId
  recipientUsername String?
  cctpMessageId     String?  @unique
  timestamp         DateTime @default(now())
}

model PaymentRequest {
  id          String   @id @default(uuid())
  fromAddress String
  toAddress   String?
  amount      String
  memo        String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

model SyncState {
  key   String @id
  value String
}

model RecoveryRequest {
  id            String   @id @default(uuid())
  transactionId String   @unique
  userAddress   String
  amount        String
  sourceChain   Int
  destChain     Int
  status        String   @default("PENDING") // PENDING, RECOVERED, FAILED
  cctpMessageId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PayoutTemplate {
  id           String   @id @default(uuid())
  name         String
  description  String?
  recipients   String   // JSON string representing Recipient[]: { address: string, name?: string, amount: string }
  totalAmount  String   // Total USDC in 6-decimal format (string)
  ownerAddress String   // User who created the template
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ScheduledPayout {
  id           String   @id @default(uuid())
  name         String
  description  String?
  frequency    String   // MONTHLY, WEEKLY, ONE_TIME
  recipients   String   // JSON string representing Recipient[]: { address: string, name?: string, amount: string }
  totalAmount  String   // Total USDC in 6-decimal format (string)
  nextRun      DateTime
  status       String   @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED
  ownerAddress String   // User who created the schedule
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


